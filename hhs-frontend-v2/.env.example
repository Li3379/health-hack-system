# ===========================================
# HHS Frontend Environment Variables
# ===========================================
# Copy this file to .env.development or .env.production
# and fill in your values
#
# For development: cp .env.example .env.development
# For production:  cp .env.example .env.production
#
# NEVER commit .env files to version control!
# ===========================================

# ====================
# API Configuration
# ====================
# Backend API base URL
# 
# IMPORTANT: Do NOT include /api suffix!
# The frontend already adds /api prefix to all API calls.
#
# Examples:
# - Development: http://localhost:8082
# - Production (domain): https://yourdomain.com
# - Production (IP): http://47.112.6.180
# - Docker deployment: leave empty to use nginx proxy
#
# WRONG: VITE_API_BASE_URL=http://47.112.6.180/api  (causes /api/api/... error)
# RIGHT: VITE_API_BASE_URL=http://47.112.6.180     (results in /api/... correctly)
VITE_API_BASE_URL=http://localhost:8082

# WebSocket base URL for real-time features
#
# IMPORTANT: Do NOT include /ws suffix!
# The frontend already adds /ws/realtime to the WebSocket URL.
#
# Examples:
# - Development: ws://localhost:8082
# - Production (domain): wss://yourdomain.com
# - Production (IP): ws://47.112.6.180
# - Docker deployment: leave empty to auto-detect from browser URL
#
# If left empty, the WebSocket URL will be automatically constructed
# from the current page URL (recommended for Docker deployments)
VITE_WS_BASE_URL=ws://localhost:8082

# ====================
# Deployment Guide
# ====================
#
# For Docker deployment with nginx:
# - Leave both variables empty
# - Nginx will proxy /api/* to backend and /ws/* to WebSocket
# - WebSocket URL will be auto-detected from browser URL
#
# For direct IP deployment (e.g., http://47.112.6.180):
# - VITE_API_BASE_URL=http://47.112.6.180
# - VITE_WS_BASE_URL=ws://47.112.6.180
#
# For domain deployment (e.g., https://yourdomain.com):
# - VITE_API_BASE_URL=https://yourdomain.com
# - VITE_WS_BASE_URL=wss://yourdomain.com
#
# ====================
# Environment Notes
# ====================
# Vite automatically loads environment-specific files:
# - .env                - loaded in all environments
# - .env.local          - loaded in all environments, gitignored
# - .env.development    - loaded when running npm run dev
# - .env.production     - loaded when running npm run build
#
# Environment variables must be prefixed with VITE_ to be
# accessible in the browser via import.meta.env.VITE_*
#
# Example usage in Vue components:
# const apiUrl = import.meta.env.VITE_API_BASE_URL
# const wsUrl = import.meta.env.VITE_WS_BASE_URL