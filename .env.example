# ===========================================
# HHS Docker Compose Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env
#
# NEVER commit .env to version control!
# ===========================================

# ====================
# Spring Profile
# ====================
# Active profile: dev, prod
# Development: dev (default)
# Production: prod
SPRING_PROFILES_ACTIVE=dev

# ====================
# Database Configuration
# ====================
# MySQL root password (REQUIRED)
# Used by both MySQL container and backend connection
DB_PASSWORD=your_mysql_password_here

# ====================
# Redis Configuration
# ====================
# Redis password (REQUIRED)
# Used by both Redis container and backend connection
REDIS_PASSWORD=your_redis_password_here

# ====================
# Security Configuration
# ====================
# JWT secret for token signing (REQUIRED)
# Must be at least 32 characters (256 bits) for HS256 algorithm
# Generate a secure secret: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here_minimum_32_characters

# CORS allowed origins (comma-separated)
# Development: http://localhost
# Production: https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost

# ====================
# AI Services
# ====================
# Alibaba Tongyi Qianwen API key for AI features
# Get your key at: https://dashscope.console.aliyun.com/
# Required for: AI health advisor, metric parsing, health scoring
DASH_SCOPE_API_KEY=your_dashscope_api_key_here

# ====================
# Device Integration (Optional)
# ====================
# AES-256 encryption key for OAuth token storage
# Generate with: openssl rand -base64 32
# Required for: Huawei Health, Xiaomi Health sync
DEVICE_ENCRYPTION_KEY=your_encryption_key_here_32_bytes

# Huawei Health OAuth (register at https://developer.huawei.com)
HUAWEI_CLIENT_ID=your_huawei_client_id
HUAWEI_CLIENT_SECRET=your_huawei_client_secret

# Xiaomi Health OAuth (register at https://dev.mi.com)
XIAOMI_CLIENT_ID=your_xiaomi_client_id
XIAOMI_CLIENT_SECRET=your_xiaomi_client_secret

# ====================
# OCR Service (Optional)
# ====================
# Baidu OCR for image text recognition
BAIDU_OCR_API_KEY=your_baidu_ocr_api_key
BAIDU_OCR_SECRET_KEY=your_baidu_ocr_secret_key

# ====================
# Email Push (Optional)
# ====================
# SMTP configuration for email notifications
MAIL_HOST=smtp.example.com
MAIL_PORT=465
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_email_authorization_code

# ====================
# Notes
# ====================
# Required variables (application will fail to start):
# - DB_PASSWORD
# - REDIS_PASSWORD
# - JWT_SECRET
#
# Recommended for full functionality:
# - DASH_SCOPE_API_KEY (AI features)
# - DEVICE_ENCRYPTION_KEY (device sync)
#
# Optional variables:
# - HUAWEI_* (Huawei Health sync)
# - XIAOMI_* (Xiaomi Health sync)
# - BAIDU_OCR_* (OCR data entry)
# - MAIL_* (email notifications)